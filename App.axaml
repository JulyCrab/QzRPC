<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:suki="clr-namespace:SukiUI;assembly=SukiUI"
             xmlns:sys="clr-namespace:System;assembly=netstandard"
             x:Class="QobuzRPC.App"
             xmlns:local="using:QobuzRPC"
             RequestedThemeVariant="Dark">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Resources>
        <ResourceDictionary>
            <!-- Color Palette Definitions -->
            <Color x:Key="PrimaryColor">#0078D4</Color>
            <Color x:Key="SecondaryColor">#005A9E</Color>
            <Color x:Key="AccentColor">#4A9EFF</Color>
            <Color x:Key="BackgroundColor">#0A0A0A</Color>
            <Color x:Key="CardColor">#1A1A1A</Color>
            <Color x:Key="BorderColor">#2A2A2A</Color>

            <!-- Brushes -->
            <SolidColorBrush x:Key="PrimaryBrush" Color="{DynamicResource PrimaryColor}"/>
            <SolidColorBrush x:Key="SecondaryBrush" Color="{DynamicResource SecondaryColor}"/>
            <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource AccentColor}"/>
            <SolidColorBrush x:Key="BackgroundBrush" Color="{DynamicResource BackgroundColor}"/>
            <SolidColorBrush x:Key="CardBrush" Color="{DynamicResource CardColor}"/>
            <SolidColorBrush x:Key="BorderBrush" Color="{DynamicResource BorderColor}"/>

            <!-- Gradient Brushes -->
            <LinearGradientBrush x:Key="PrimaryGradient" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="{DynamicResource PrimaryColor}" Offset="0"/>
                <GradientStop Color="{DynamicResource SecondaryColor}" Offset="1"/>
            </LinearGradientBrush>

            <LinearGradientBrush x:Key="CardGradient" StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#1A1A1A" Offset="0"/>
                <GradientStop Color="#1E1E1E" Offset="1"/>
            </LinearGradientBrush>

            <!-- Spacing and Sizing -->
            <Thickness x:Key="CardPadding">24</Thickness>
            <CornerRadius x:Key="CardCornerRadius">12</CornerRadius>
            <CornerRadius x:Key="ButtonCornerRadius">10</CornerRadius>

            <!-- Typography -->
            <FontFamily x:Key="MonospaceFont">Consolas, Courier New, monospace</FontFamily>

            <!-- Animation Durations -->
            <sys:TimeSpan x:Key="FastAnimation">0:0:0.15</sys:TimeSpan>
            <sys:TimeSpan x:Key="NormalAnimation">0:0:0.25</sys:TimeSpan>
        </ResourceDictionary>
    </Application.Resources>
  
    <Application.Styles>
        <suki:SukiTheme ThemeColor="Blue" />
    </Application.Styles>
</Application>